# ─── Required ────────────────────────────────────────────
COOKIDOO_EMAIL=your@email.com
COOKIDOO_PASSWORD=your-password
TELEGRAM_BOT_TOKEN=123456789:ABCdef...
TELEGRAM_CHAT_ID=-100123456789

# ─── Optional: Cookidoo ─────────────────────────────────
# COOKIDOO_COUNTRY=de
# COOKIDOO_LANGUAGE=de-DE
# COOKIDOO_URL=https://cookidoo.de/foundation/de-DE

# ─── Optional: Voting defaults ──────────────────────────
# NUM_RECIPE_CANDIDATES=7
# VOTING_DURATION_MINUTES=120
# VOTING_DURATION_MAX_MINUTES=720
# VOTING_END_TIME_LOCAL=17:00
# MAX_DIFFICULTY=medium
# RECIPE_HISTORY_DAYS=14
# CACHE_REFRESH_HOURS=24

# ─── Optional: Webhook mode ─────────────────────────────
# WEBHOOK_HOST=0.0.0.0
# WEBHOOK_PORT=8443
# WEBHOOK_URL=https://your-domain.com:8443

# ─── Optional: Admin (comma-separated TG user IDs) ──────
# ADMIN_USER_IDS=123456789,987654321

# ─── Optional: Data directory ───────────────────────────
# DATA_DIR=/data
