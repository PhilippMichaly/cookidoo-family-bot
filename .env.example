# ─── Cookidoo (Thermomix) ────────────────────────────────────
# Deine Cookidoo-Zugangsdaten (aktives Abo erforderlich)
COOKIDOO_EMAIL=deine@email.de
COOKIDOO_PASSWORD=dein-passwort

# Ländereinstellungen (de/at/ch)
COOKIDOO_COUNTRY=de
COOKIDOO_LANGUAGE=de-DE
COOKIDOO_URL=https://cookidoo.de/foundation/de-DE

# ─── Telegram ────────────────────────────────────────────────
# Bot-Token von @BotFather (https://t.me/BotFather)
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz

# Chat-ID der Familiengruppe (mit setup_chat_id.py ermitteln)
TELEGRAM_CHAT_ID=-1001234567890

# ─── Voting ──────────────────────────────────────────────────
# Anzahl Rezeptvorschläge (5-10)
NUM_RECIPE_CANDIDATES=7

# Abstimmungsdauer in Minuten
VOTING_DURATION_MINUTES=120

# Maximale Schwierigkeit: easy, medium, difficult
MAX_DIFFICULTY=medium

# Maximale Abstimmungsdauer bei Verlängerung (Minuten)
VOTING_DURATION_MAX_MINUTES=720

# ─── Rezept-Historie ─────────────────────────────────────────
# Gewinner der letzten X Tage werden nicht erneut vorgeschlagen
RECIPE_HISTORY_DAYS=14
